---
import config from 'virtual:starlight/user-config';

const localeEntries = Object.entries(config.locales ?? {});
const localeOptions = localeEntries.map(([key, value]) => ({
  code: key === 'root' ? value.lang.toLowerCase() : key.toLowerCase(),
  pathPrefix: key === 'root' ? '' : `/${key.toLowerCase()}`,
}));
---

<script is:inline define:vars={{ FILEUNI_LOCALES: localeOptions }}>
  const FILEUNI_THEME_KEY = 'theme';
  const FILEUNI_LANG_KEY = 'lang';
  const COOKIE_MAX_AGE_SECONDS = 60 * 60 * 24 * 365;
  const defaultLocaleOption =
    FILEUNI_LOCALES.find((locale) => locale.pathPrefix === '') || FILEUNI_LOCALES[0];
  const FILEUNI_DEFAULT_LOCALE =
    defaultLocaleOption && defaultLocaleOption.code ? defaultLocaleOption.code : 'en';
  const FILEUNI_LOCALE_PREFIXES = FILEUNI_LOCALES
    .map((locale) => locale.pathPrefix)
    .filter(Boolean)
    .sort((a, b) => b.length - a.length);

  const getCookieDomain = (hostname) => {
    const normalizedHost = hostname.toLowerCase();
    if (normalizedHost === 'fileuni.com' || normalizedHost.endsWith('.fileuni.com')) {
      return '.fileuni.com';
    }
    if (normalizedHost.endsWith('.workers.dev')) {
      const labels = normalizedHost.split('.');
      if (labels.length >= 5) {
        return `.${labels.slice(-4).join('.')}`;
      }
      if (labels.length === 4) {
        return `.${labels.slice(-3).join('.')}`;
      }
    }
    return '';
  };

  const readCookie = (name) => {
    const prefix = `${name}=`;
    const cookies = document.cookie.split(';');
    for (const rawCookie of cookies) {
      const cookie = rawCookie.trim();
      if (cookie.startsWith(prefix)) {
        return decodeURIComponent(cookie.slice(prefix.length));
      }
    }
    return null;
  };

  const writeCookie = (name, value) => {
    const domain = getCookieDomain(window.location.hostname);
    const domainPart = domain ? `; domain=${domain}` : '';
    const securePart = window.location.protocol === 'https:' ? '; Secure' : '';
    document.cookie = `${name}=${encodeURIComponent(value)}; path=/; max-age=${COOKIE_MAX_AGE_SECONDS}; SameSite=Lax${securePart}${domainPart}`;
  };

  const parseTheme = (theme) =>
    theme === 'auto' || theme === 'dark' || theme === 'light' ? theme : null;

  const parseLang = (lang) => {
    if (!lang) {
      return null;
    }
    const normalized = lang.toLowerCase();
    const matchedLocale = FILEUNI_LOCALES.find((locale) => locale.code === normalized);
    return matchedLocale ? matchedLocale.code : null;
  };

  const stripLocalePrefix = (pathname) => {
    for (const prefix of FILEUNI_LOCALE_PREFIXES) {
      if (pathname === prefix) {
        return '/';
      }
      if (pathname.startsWith(`${prefix}/`)) {
        const stripped = pathname.slice(prefix.length);
        return stripped || '/';
      }
    }
    return pathname;
  };

  const getLocaleFromPath = (pathname) => {
    const matchedLocale = FILEUNI_LOCALES.find(
      (locale) =>
        locale.pathPrefix &&
        (pathname === locale.pathPrefix || pathname.startsWith(`${locale.pathPrefix}/`)),
    );
    return matchedLocale ? matchedLocale.code : FILEUNI_DEFAULT_LOCALE;
  };

  const toLocalePath = (pathname, localeCode) => {
    const targetLocale = FILEUNI_LOCALES.find((locale) => locale.code === localeCode);
    if (!targetLocale) {
      return pathname;
    }
    const basePath = stripLocalePrefix(pathname);
    if (!targetLocale.pathPrefix) {
      return basePath;
    }
    return basePath === '/' ? `${targetLocale.pathPrefix}/` : `${targetLocale.pathPrefix}${basePath}`;
  };

  const isLocaleRootPath = (pathname) => {
    const normalizedPath = pathname.endsWith('/') ? pathname : `${pathname}/`;
    return FILEUNI_LOCALES.some((locale) => {
      const localePath = locale.pathPrefix || '/';
      const normalizedLocalePath = localePath.endsWith('/') ? localePath : `${localePath}/`;
      return normalizedPath === normalizedLocalePath;
    });
  };

  const currentPath = window.location.pathname;
  const cookieLang = parseLang(readCookie(FILEUNI_LANG_KEY));
  const currentLang = getLocaleFromPath(currentPath);

  if (!cookieLang) {
    writeCookie(FILEUNI_LANG_KEY, currentLang);
  } else if (cookieLang !== currentLang && isLocaleRootPath(currentPath)) {
    const targetPath = toLocalePath(currentPath, cookieLang);
    if (targetPath !== currentPath) {
      window.location.replace(`${targetPath}${window.location.search}${window.location.hash}`);
    }
  }

  const getPreferredColorScheme = () =>
    window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';

  const resolveTheme = (theme) => (theme === 'auto' ? getPreferredColorScheme() : theme);

  const storedTheme = parseTheme(readCookie(FILEUNI_THEME_KEY)) || 'auto';
  if (!parseTheme(readCookie(FILEUNI_THEME_KEY))) {
    writeCookie(FILEUNI_THEME_KEY, 'auto');
  }
  document.documentElement.dataset.theme = resolveTheme(storedTheme);

  window.FileUniPreferenceCookie = {
    read: readCookie,
    write: writeCookie,
    parseTheme,
    parseLang,
  };

  window.StarlightThemeProvider = {
    updatePickers(theme = storedTheme) {
      const parsedTheme = parseTheme(theme) || 'auto';
      document.querySelectorAll('starlight-theme-select').forEach((picker) => {
        const select = picker.querySelector('select');
        if (select) {
          select.value = parsedTheme;
        }
        picker.querySelectorAll('[data-theme-value]').forEach((option) => {
          if (!(option instanceof HTMLButtonElement)) {
            return;
          }
          const isActive = option.dataset.themeValue === parsedTheme;
          option.classList.toggle('is-active', isActive);
          option.setAttribute('aria-pressed', String(isActive));
        });
      });
    },
  };
</script>
