---
import { Icon } from '@astrojs/starlight/components';
import {
  FILEUNI_CONTROL_METRICS,
  getNextBinaryTheme,
  parseBrowserThemePreference,
} from '../i18n/core';

const controlStyle = [
  `--fu-control-size:${FILEUNI_CONTROL_METRICS.buttonSizePx}px`,
  `--fu-control-min-height:${FILEUNI_CONTROL_METRICS.buttonMinHeightPx}px`,
  `--fu-control-radius:${FILEUNI_CONTROL_METRICS.borderRadiusPx}px`,
  `--fu-control-icon-size:${FILEUNI_CONTROL_METRICS.iconSizePx}px`,
].join(';');
---

<starlight-theme-select>
  <button
    type="button"
    class="fu-theme-toggle"
    style={controlStyle}
    aria-label={Astro.locals.t('themeSelect.accessibleLabel')}
    title={Astro.locals.t('themeSelect.accessibleLabel')}
  >
    <span class="fu-theme-icon fu-theme-icon--sun" aria-hidden="true"><Icon name="sun" /></span>
    <span class="fu-theme-icon fu-theme-icon--moon" aria-hidden="true"><Icon name="moon" /></span>
  </button>
</starlight-theme-select>

<script>
  const THEME_COOKIE_KEY = 'theme';

  const getCookieTheme = () => {
    const cookieApi = window.FileUniPreferenceCookie;
    if (!cookieApi || typeof cookieApi.read !== 'function') {
      return null;
    }
    return parseBrowserThemePreference(cookieApi.read(THEME_COOKIE_KEY));
  };

  const saveCookieTheme = (theme) => {
    const cookieApi = window.FileUniPreferenceCookie;
    if (!cookieApi || typeof cookieApi.write !== 'function') {
      return;
    }
    cookieApi.write(THEME_COOKIE_KEY, theme);
  };

  const getPreferredColorScheme = () =>
    matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';

  const resolveTheme = (theme) => {
    const parsed = parseBrowserThemePreference(theme) || 'auto';
    return parsed === 'auto' ? getPreferredColorScheme() : parsed;
  };

  const applyResolvedTheme = (resolvedTheme) => {
    document.documentElement.dataset.theme = resolvedTheme;
  };

  const initTheme = () => {
    const cookieTheme = getCookieTheme() || 'auto';
    applyResolvedTheme(resolveTheme(cookieTheme));
  };

  const toggleTheme = () => {
    const current = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
    const next = getNextBinaryTheme(current);
    applyResolvedTheme(next);
    saveCookieTheme(next);
  };

  class StarlightThemeSelect extends HTMLElement {
    constructor() {
      super();
      initTheme();

      const button = this.querySelector('button.fu-theme-toggle');
      if (button) {
        button.addEventListener('click', () => toggleTheme());
      }

      matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
        if ((getCookieTheme() || 'auto') === 'auto') {
          initTheme();
        }
      });
    }
  }

  if (!customElements.get('starlight-theme-select')) {
    customElements.define('starlight-theme-select', StarlightThemeSelect);
  }
</script>
