---
import { DOCS_LOCALE_OPTIONS } from '../i18n/locales';

type LocaleOption = {
  code: string;
  label: string;
  flag: string;
  pathPrefix: string;
};

const currentPath = Astro.url.pathname;
const localeOptions: LocaleOption[] = DOCS_LOCALE_OPTIONS;
const currentLocale =
  localeOptions.find((option) =>
    option.pathPrefix
      ? currentPath === option.pathPrefix || currentPath.startsWith(`${option.pathPrefix}/`)
      : !localeOptions.some(
          (candidate) =>
            candidate.pathPrefix &&
            (currentPath === candidate.pathPrefix || currentPath.startsWith(`${candidate.pathPrefix}/`)),
        ),
  ) ?? localeOptions[0];

const currentFlag = currentLocale.flag || '🌐';
---

<starlight-lang-select>
  <button
    type="button"
    class="fu-lang-toggle"
    data-current-lang={currentLocale.code}
    aria-expanded="false"
    aria-haspopup="menu"
    aria-label={Astro.locals.t('languageSelect.accessibleLabel')}
  >
    <span class="fu-lang-flag" aria-hidden="true">{currentFlag}</span>
  </button>
  <div class="fu-lang-menu" hidden>
    {localeOptions.map((option) => (
      <button
        type="button"
        class:list={['fu-lang-menu-item', option.code === currentLocale.code && 'is-active']}
        data-lang-value={option.code}
        data-lang-path-prefix={option.pathPrefix}
        role="menuitemradio"
        aria-checked={String(option.code === currentLocale.code)}
      >
        <span>{option.label}</span>
      </button>
    ))}
  </div>
</starlight-lang-select>

<script is:inline define:vars={{ localeOptions }}>
  const LANG_COOKIE_KEY = 'lang';
  const localePrefixes = localeOptions
    .map((option) => option.pathPrefix)
    .filter(Boolean)
    .sort((a, b) => b.length - a.length);

  const stripLocalePrefix = (pathname) => {
    for (const prefix of localePrefixes) {
      if (pathname === prefix) {
        return '/';
      }
      if (pathname.startsWith(`${prefix}/`)) {
        const stripped = pathname.slice(prefix.length);
        return stripped || '/';
      }
    }
    return pathname;
  };

  const toLocalePath = (pathname, localeCode) => {
    const targetOption = localeOptions.find((option) => option.code === localeCode);
    if (!targetOption) {
      return pathname;
    }
    const basePath = stripLocalePrefix(pathname);
    if (!targetOption.pathPrefix) {
      return basePath;
    }
    return basePath === '/' ? `${targetOption.pathPrefix}/` : `${targetOption.pathPrefix}${basePath}`;
  };

  class StarlightLanguageSelect extends HTMLElement {
    constructor() {
      super();
      const button = this.querySelector('button.fu-lang-toggle');
      const menu = this.querySelector('.fu-lang-menu');
      const options = Array.from(this.querySelectorAll('button.fu-lang-menu-item'));
      if (!button || !menu || options.length === 0) {
        return;
      }

      const closeMenu = () => {
        menu.hidden = true;
        button.setAttribute('aria-expanded', 'false');
      };

      const openMenu = () => {
        menu.hidden = false;
        button.setAttribute('aria-expanded', 'true');
      };

      button.addEventListener('click', () => {
        if (menu.hidden) {
          openMenu();
          return;
        }
        closeMenu();
      });

      options.forEach((option) => {
        option.addEventListener('click', () => {
          const nextLang = option.dataset.langValue;
          if (!nextLang) {
            return;
          }
          if (
            window.FileUniPreferenceCookie &&
            typeof window.FileUniPreferenceCookie.write === 'function'
          ) {
            window.FileUniPreferenceCookie.write(LANG_COOKIE_KEY, nextLang);
          }
          const targetPath = toLocalePath(window.location.pathname, nextLang);
          window.location.pathname = targetPath;
        });
      });

      document.addEventListener('click', (event) => {
        if (!(event.target instanceof Node) || this.contains(event.target)) {
          return;
        }
        closeMenu();
      });

      this.addEventListener('keydown', (event) => {
        if (!(event instanceof KeyboardEvent)) {
          return;
        }
        if (event.key === 'Escape') {
          closeMenu();
          button.focus();
        }
      });
    }
  }
  if (!customElements.get('starlight-lang-select')) {
    customElements.define('starlight-lang-select', StarlightLanguageSelect);
  }
</script>
