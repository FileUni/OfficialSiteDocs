---
import { DOCS_LOCALE_OPTIONS } from '../i18n/locales';
import {
  FILEUNI_CONTROL_METRICS,
  FILEUNI_LANGUAGE_MENU_CLASSNAMES,
  FILEUNI_TRANSLATION_ICON_PATHS,
  type SupportedLocale,
} from '../i18n/core';

type LocaleOption = {
  code: SupportedLocale;
  label: string;
  pathPrefix: string;
};

const currentPath = Astro.url.pathname;
const localeOptions: LocaleOption[] = DOCS_LOCALE_OPTIONS;
const currentLocale =
  localeOptions.find((option) =>
    option.pathPrefix
      ? currentPath === option.pathPrefix || currentPath.startsWith(`${option.pathPrefix}/`)
      : !localeOptions.some(
          (candidate) =>
            candidate.pathPrefix &&
            (currentPath === candidate.pathPrefix || currentPath.startsWith(`${candidate.pathPrefix}/`)),
        ),
  ) ?? localeOptions[0];

const controlStyle = [
  `--fu-control-size:${FILEUNI_CONTROL_METRICS.buttonSizePx}px`,
  `--fu-control-min-height:${FILEUNI_CONTROL_METRICS.buttonMinHeightPx}px`,
  `--fu-control-radius:${FILEUNI_CONTROL_METRICS.borderRadiusPx}px`,
  `--fu-control-menu-width:${FILEUNI_CONTROL_METRICS.menuWidthPx}px`,
].join(';');
---

<starlight-lang-select>
  <button
    type="button"
    class={`fu-lang-toggle ${FILEUNI_LANGUAGE_MENU_CLASSNAMES.trigger}`}
    style={controlStyle}
    data-current-lang={currentLocale.code}
    aria-expanded="false"
    aria-haspopup="menu"
    aria-label={Astro.locals.t('languageSelect.accessibleLabel')}
  >
    <span class="fu-lang-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        {FILEUNI_TRANSLATION_ICON_PATHS.map((path) => (
          <path d={path}></path>
        ))}
      </svg>
    </span>
    <span class="fu-lang-current-label">{currentLocale.label}</span>
  </button>
  <div class={`fu-lang-menu ${FILEUNI_LANGUAGE_MENU_CLASSNAMES.menu}`} style={controlStyle} hidden>
    {localeOptions.map((option) => (
      <button
        type="button"
        class:list={[
          'fu-lang-menu-item',
          FILEUNI_LANGUAGE_MENU_CLASSNAMES.item,
          option.code === currentLocale.code && 'is-active',
        ]}
        data-lang-value={option.code}
        data-lang-path-prefix={option.pathPrefix}
        role="menuitemradio"
        aria-checked={String(option.code === currentLocale.code)}
      >
        <span>{option.label}</span>
      </button>
    ))}
  </div>
</starlight-lang-select>

<script>
  import { initDocsLanguageSelect } from '../scripts/language-select';

  initDocsLanguageSelect();
</script>
