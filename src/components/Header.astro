---
import config from 'virtual:starlight/user-config';
import type { SupportedLocale } from '../i18n/core';

import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const locale = Astro.locals.starlightRoute.locale;

type LocaleKey = 'root' | SupportedLocale;

const LOCALE_META: Record<LocaleKey, {
  labels: {
    home: string;
    download: string;
    docs: string;
    login: string;
    getStarted: string;
  };
  homeHref: string;
  downloadHref: string;
  docsHref: string;
  loginHref: string;
  registerHref: string;
}> = {
  root: {
    labels: {
      home: 'Home',
      download: 'Download',
      docs: 'Docs',
      login: 'Login',
      getStarted: 'Get Started',
    },
    homeHref: 'https://fileuni.com/',
    downloadHref: 'https://fileuni.com/download',
    docsHref: '/',
    loginHref: 'https://fileuni.com/user/login',
    registerHref: 'https://fileuni.com/user/register',
  },
  'zh-CN': {
    labels: {
      home: '首页',
      download: '下载',
      docs: '文档',
      login: '登录',
      getStarted: '立即开始',
    },
    homeHref: 'https://fileuni.com/zh-CN/',
    downloadHref: 'https://fileuni.com/zh-CN/download',
    docsHref: '/zh-CN/',
    loginHref: 'https://fileuni.com/user/login#zh-CN',
    registerHref: 'https://fileuni.com/user/register#zh-CN',
  },
  'zh-Hant': {
    labels: {
      home: '首頁',
      download: '下載',
      docs: '文件',
      login: '登入',
      getStarted: '立即開始',
    },
    homeHref: 'https://fileuni.com/zh-Hant/',
    downloadHref: 'https://fileuni.com/zh-Hant/download',
    docsHref: '/zh-Hant/',
    loginHref: 'https://fileuni.com/user/login#zh-Hant',
    registerHref: 'https://fileuni.com/user/register#zh-Hant',
  },
  es: {
    labels: {
      home: 'Inicio',
      download: 'Descargar',
      docs: 'Docs',
      login: 'Entrar',
      getStarted: 'Empezar',
    },
    homeHref: 'https://fileuni.com/es/',
    downloadHref: 'https://fileuni.com/es/download',
    docsHref: '/es/',
    loginHref: 'https://fileuni.com/user/login#es',
    registerHref: 'https://fileuni.com/user/register#es',
  },
  de: {
    labels: {
      home: 'Home',
      download: 'Download',
      docs: 'Docs',
      login: 'Login',
      getStarted: 'Get Started',
    },
    homeHref: 'https://fileuni.com/de/',
    downloadHref: 'https://fileuni.com/de/download',
    docsHref: '/de/',
    loginHref: 'https://fileuni.com/user/login#de',
    registerHref: 'https://fileuni.com/user/register#de',
  },
  fr: {
    labels: {
      home: 'Home',
      download: 'Download',
      docs: 'Docs',
      login: 'Login',
      getStarted: 'Get Started',
    },
    homeHref: 'https://fileuni.com/fr/',
    downloadHref: 'https://fileuni.com/fr/download',
    docsHref: '/fr/',
    loginHref: 'https://fileuni.com/user/login#fr',
    registerHref: 'https://fileuni.com/user/register#fr',
  },
  ru: {
    labels: {
      home: 'Home',
      download: 'Download',
      docs: 'Docs',
      login: 'Login',
      getStarted: 'Get Started',
    },
    homeHref: 'https://fileuni.com/ru/',
    downloadHref: 'https://fileuni.com/ru/download',
    docsHref: '/ru/',
    loginHref: 'https://fileuni.com/user/login#ru',
    registerHref: 'https://fileuni.com/user/register#ru',
  },
  ja: {
    labels: {
      home: 'Home',
      download: 'Download',
      docs: 'Docs',
      login: 'Login',
      getStarted: 'Get Started',
    },
    homeHref: 'https://fileuni.com/ja/',
    downloadHref: 'https://fileuni.com/ja/download',
    docsHref: '/ja/',
    loginHref: 'https://fileuni.com/user/login#ja',
    registerHref: 'https://fileuni.com/user/register#ja',
  },
};

const meta = LOCALE_META[(locale as LocaleKey)] ?? LOCALE_META.root;

const homeHref = meta.homeHref;
const downloadHref = meta.downloadHref;
const docsHref = meta.docsHref;
const loginHref = meta.loginHref;
const registerHref = meta.registerHref;
---

<div class="fu-docs-header sl-flex">
  <div class="fu-docs-header-left sl-flex">
    <SiteTitle />
    <nav class="fu-docs-nav" aria-label="Primary navigation">
      <a href={homeHref}>{meta.labels.home}</a>
      <a href={downloadHref}>{meta.labels.download}</a>
      <a href={docsHref} class="is-active">{meta.labels.docs}</a>
    </nav>
  </div>

  <div class="fu-docs-header-right sl-flex print:hidden">
    {shouldRenderSearch && (
      <div class="fu-docs-search">
        <Search />
      </div>
    )}
    <ThemeSelect />
    <LanguageSelect />
    <a href={loginHref} class="fu-auth-link fu-auth-login">{meta.labels.login}</a>
    <a href={registerHref} class="fu-auth-link fu-auth-register">{meta.labels.getStarted}</a>
  </div>
</div>
